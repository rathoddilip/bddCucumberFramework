# ==============================
# Browser Configuration
# ==============================
# Supported values: chrome | firefox | edge
browser=chrome

# Run in headless mode: true | false
headless=false

# ==============================
# Application URL
# ==============================
# Replace with the actual application login URL before running tests.
# Can also be overridden at runtime: mvn test -Dbase.url=https://...
base.url=https://your-app-url/login

# ==============================
# Timeouts (in seconds)
# ==============================
implicit.wait=10
explicit.wait=15
page.load.timeout=30

# ==============================
# Screenshot
# ==============================
screenshot.dir=screenshots
